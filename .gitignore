# Dependencies
node_modules

# Build output
dist
dist-ssr
*.tsbuildinfo

# Environment secrets (keep .env.example tracked)
.env
.env.*
!.env.example

# Logs
logs
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*
lerna-debug.log*

# PartyKit / Cloudflare local dev state
.partykit/
.wrangler/

# Vite
*.local
vite.config.*.timestamp-*

# Test coverage
coverage/

# Editor directories and files
.claude/
.cursor/
.vscode/*
!.vscode/extensions.json
.idea/
*.suo
*.ntvs*
*.njsproj
*.sln
*.sw?

# OS files
.DS_Store
Thumbs.db
Desktop.ini
ehthumbs.db

# Uploaded portraits (keep folder via .gitkeep)
public/portraits/*
!public/portraits/.gitkeep

# Dev-uploaded tokens and campaign icons (already-tracked files stay tracked)
public/tokens/*
public/campaign-icons/*
